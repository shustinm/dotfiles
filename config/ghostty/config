font-thicken = true
font-thicken-strength = 100
theme = catppuccin-mocha.conf
window-save-state = always
macos-titlebar-style = tabs
macos-window-buttons = hidden
macos-option-as-alt = left
font-size = 18
shell-integration-features = ssh-env,ssh-terminfo

keybind = performable:ctrl+shift+alt+super+h=goto_split:left
keybind = performable:ctrl+shift+alt+super+l=goto_split:right
keybind = performable:ctrl+shift+alt+super+j=goto_split:down
keybind = performable:ctrl+shift+alt+super+k=goto_split:up
keybind = performable:ctrl+enter=toggle_split_zoom
split-preserve-zoom = navigation
keybind = alt+shift+z=goto_split:next
keybind = cmd+shift+m=prompt_surface_title

